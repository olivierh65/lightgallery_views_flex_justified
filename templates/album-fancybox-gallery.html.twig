{#
  Recursive template to display albums + sub-groups,
  with Flexbox at all levels for a responsive layout.
  Uses Fancybox for lightbox functionality.
#}
{% macro render_group_recursive(group, options, parent_id, level) %}

	{# ---- Group item (for Flexbox of the parent) ---- #}
	<div class="flexbox-item group-item level-{{ level }}" data-level="{{ level }}">

		{# ---- GROUP TITLE (if present) ---- #}
		{% if group.title %}
			<div class="group-title-wrapper level-{{ level }}">
				{% if group.title|striptags|trim|length == 0 %}
					<span class="group-title level-{{ level }} placeholder" aria-hidden="true">
					&nbsp;
					</span>
				{% else %}
					<span class="group-title level-{{ level }}">
						{{ group.title }}
					</span>
				{% endif %}
			</div>
		{% endif %}

		{# Check if there is content #}
		{% set has_albums = group.albums is defined and group.albums|length > 0 %}
		{% set has_subgroups = group.subgroups is defined and group.subgroups|length > 0 %}

		{% if has_albums or has_subgroups %}
			{# ---- FLEXBOX CONTAINER FOR CHILDREN ---- #}
			{% set group_id = 'flexbox-container-' ~ random() %}
			<div class="flexbox-container" id="{{ group_id }}" data-parent="{{ parent_id }}" data-level="{{ level }}">

				{# ---- ALBUMS OF THE GROUP ---- #}
				{% if has_albums %}
					{% for album in group.albums %}
						{% set security_query = 's_t=' ~ album.s_token ~ '&s_id=' ~ album.s_id ~ '&n_id=' ~ album.nid %}

						<div class="flexbox-item album-item">

							{# Couverture de l'album — ouvre Fancybox au clic #}
							<a href="#"
							   class="album-cover"
							   data-album-id="{{ album.id }}"
							   data-once="fb-album">
								<span class="album-title">{{ album.title }}</span>
								{% if album.image_url %}
									{% set cover_sep = (album.image_url|split('?')|length > 1) ? '&' : '?' %}
									<img
										loading="lazy"
										src="{{ album.image_url }}{{ cover_sep }}{{ security_query }}&m_id={{ album.image_url_id }}"
										class="media-thumbnail album-img"
										alt="{{ album.title }}">
								{% endif %}
							</a>

							{# Fancybox items — cachés, activés au clic sur la couverture #}
							<div id="{{ album.id }}" class="fancybox-album" style="display:none;">
								{% for media in album.medias %}
									{% set url_sep = (media.url|split('?')|length > 1) ? '&' : '?' %}
									{% set thumb_sep = (media.thumbnail|split('?')|length > 1) ? '&' : '?' %}
									{% set media_caption = media.caption|default(media.description|default('')) %}

									{% if media.mime_type starts with 'image/' %}

										<a href="{{ media.url }}{{ url_sep }}{{ security_query }}&m_id={{ media.media_id }}"
										   data-fancybox="{{ album.id }}"
										   data-thumb="{{ media.thumbnail }}{{ thumb_sep }}{{ security_query }}&m_id={{ media.media_id }}"
										   data-caption="{% if media_caption and media_caption|length > 0 %}{{ media_caption }}{% endif %}"
										   class="fancybox__item">
											<img
												loading="lazy"
												src="{{ media.thumbnail }}{{ thumb_sep }}{{ security_query }}&m_id={{ media.media_id }}"
												alt="{{ media.alt|default(media.title|default('')) }}"/>
										</a>

									{% elseif media.mime_type starts with 'video/' %}

										<a href="{{ media.url }}{{ url_sep }}{{ security_query }}&m_id={{ media.media_id }}"
										   data-fancybox="{{ album.id }}"
										   data-thumb="{{ media.thumbnail }}{{ thumb_sep }}{{ security_query }}&m_id={{ media.media_id }}"
										   data-caption="{% if media_caption and media_caption|length > 0 %}{{ media_caption }}{% endif %}"
										   data-type="video"
										   class="fancybox__item">
											{% if media.thumbnail %}
												<img
													loading="lazy"
													src="{{ media.thumbnail }}{{ thumb_sep }}{{ security_query }}&m_id={{ media.media_id }}"
													alt="{{ media.title|default('') }}"/>
											{% endif %}
										</a>

									{% endif %}
								{% endfor %}
							</div>

							{# Caption album (if present) #}
							{% if album.caption and (album.caption|length > 0) %}
								<div class="album-caption">
									{{ album.caption|raw }}
								</div>
							{% endif %}

						</div>
					{% endfor %}
				{% endif %}

				{# ---- SUB-GROUPS (RECURSIVE) ---- #}
				{% if has_subgroups %}
					{% for subgroup in group.subgroups %}
						{{ _self.render_group_recursive(subgroup, options, group_id, level + 1) }}
					{% endfor %}
				{% endif %}

			</div>
		{% endif %}

	</div>

{% endmacro %}


{# ================= MAIN TEMPLATE ===================== #}

{% import _self as macros %}

{% set classes = [
  'album-gallery-view',
  'view',
  'view-album-flexbox'
] %}

<div{{ attributes.addClass(classes) }} id="album-gallery-{{ random() }}">

	{# --- ROOT FLEXBOX CONTAINER ---- #}
	{% set root_id = 'flexbox-root-' ~ random() %}
	<div class="flexbox-container flexbox-root" id="{{ root_id }}" data-level="root">

		{% if groups|length > 0 %}
			{% for group in groups %}
				{{ macros.render_group_recursive(group, options, root_id, 0) }}
			{% endfor %}
		{% else %}
			<p class="no-results">Aucun album trouvé.</p>
		{% endif %}

	</div>

</div>